{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://friday.local/schemas/contracts/v1/physical-connector-capability.schema.json",
  "title": "FRIDAY Physical Connector Capability Manifest",
  "description": "Capability contract for plugin-based IoT and robotics connectors.",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schemaVersion"
    },
    "connector_id": {
      "$ref": "#/$defs/connectorId"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "connector_kind": {
      "$ref": "#/$defs/connectorKind"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_version",
    "connector_id",
    "provider",
    "connector_kind",
    "capabilities"
  ],
  "additionalProperties": false,
  "$defs": {
    "connectorId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "connectorKind": {
      "type": "string",
      "enum": [
        "iot",
        "robotics",
        "industrial",
        "custom"
      ]
    },
    "capabilityType": {
      "type": "string",
      "enum": [
        "sensor",
        "actuator",
        "hybrid"
      ]
    },
    "tagArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "capability": {
      "type": "object",
      "properties": {
        "capability_id": {
          "$ref": "#/$defs/connectorId"
        },
        "capability_type": {
          "$ref": "#/$defs/capabilityType"
        },
        "command": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]{2,63}$"
        },
        "risk_tier": {
          "$ref": "common.schema.json#/$defs/riskTier"
        },
        "requires_sandbox_approval": {
          "type": "boolean"
        },
        "simulation_supported": {
          "type": "boolean"
        },
        "safety_tags": {
          "$ref": "#/$defs/tagArray"
        },
        "telemetry_fields": {
          "$ref": "#/$defs/tagArray"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "capability_id",
        "capability_type",
        "command",
        "risk_tier",
        "requires_sandbox_approval",
        "simulation_supported"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "capability_type": {
                "enum": [
                  "actuator",
                  "hybrid"
                ]
              }
            },
            "required": [
              "capability_type"
            ]
          },
          "then": {
            "properties": {
              "requires_sandbox_approval": {
                "const": true
              }
            }
          }
        }
      ]
    }
  }
}
