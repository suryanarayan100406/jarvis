{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://friday.local/schemas/contracts/v1/telemetry-envelope.schema.json",
  "title": "FRIDAY Telemetry Envelope Contract",
  "description": "Canonical telemetry event envelope for runtime observability and audit streams.",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schemaVersion"
    },
    "event_id": {
      "$ref": "common.schema.json#/$defs/uuid"
    },
    "timestamp": {
      "$ref": "common.schema.json#/$defs/isoTimestamp"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "severity": {
      "$ref": "common.schema.json#/$defs/severity"
    },
    "source": {
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "pattern": "^[a-z0-9._-]{2,100}$"
        },
        "host": {
          "type": "string",
          "minLength": 1
        },
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "required": [
        "component",
        "host"
      ],
      "additionalProperties": false
    },
    "run_context": {
      "type": "object",
      "properties": {
        "run_id": {
          "$ref": "common.schema.json#/$defs/uuid"
        },
        "request_id": {
          "$ref": "common.schema.json#/$defs/uuid"
        },
        "phase_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "policy_decision": {
      "$ref": "common.schema.json#/$defs/policyDecision"
    },
    "trace": {
      "$ref": "common.schema.json#/$defs/traceContext"
    },
    "integrity": {
      "type": "object",
      "properties": {
        "chain_id": {
          "$ref": "common.schema.json#/$defs/uuid"
        },
        "event_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "prev_event_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "signature": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "chain_id",
        "event_hash",
        "prev_event_hash"
      ],
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "schema_version",
    "event_id",
    "timestamp",
    "event_type",
    "severity",
    "source",
    "payload",
    "trace",
    "integrity"
  ],
  "additionalProperties": false
}
